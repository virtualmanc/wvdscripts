#region --- Configuration ---
$TenantId     = ""
$ClientId     = ""
$ClientSecret = ""   # Use cert or managed identity in production
$OutputPath   = "C:\Temp\IntuneReport"
$PollInterval = 30
$MaxAttempts  = 100
$BaseUrl      = "https://graph.microsoft.com/v1.0"
#endregion

$ScriptStart = Get-Date

#region --- Step 0: Get Access Token ---
Write-Host "[*] Acquiring access token..." -ForegroundColor Cyan

$tokenBody = @{
    grant_type    = "client_credentials"
    scope         = "https://graph.microsoft.com/.default"
    client_id     = $ClientId
    client_secret = $ClientSecret
}

$tokenResponse = Invoke-RestMethod `
    -Method Post `
    -Uri "https://login.microsoftonline.com/$TenantId/oauth2/v2.0/token" `
    -Body $tokenBody

$headers = @{
    Authorization  = "Bearer $($tokenResponse.access_token)"
    "Content-Type" = "application/json"
}

Write-Host "[+] Token acquired." -ForegroundColor Green
#endregion

#region --- Step 1: Create Export Job ---
Write-Host "[*] Creating export job..." -ForegroundColor Cyan

$JobStart = Get-Date

$jobBody = @{
    reportName = "DeviceConfigurationPolicyStatuses"
    format     = "csv"
} | ConvertTo-Json

$jobResponse = Invoke-RestMethod `
    -Method Post `
    -Uri "$BaseUrl/deviceManagement/reports/exportJobs" `
    -Headers $headers `
    -Body $jobBody

$jobId = $jobResponse.id
Write-Host "[+] Export job created. Job ID: $jobId" -ForegroundColor Green
#endregion

#region --- Step 2: Poll for Completion ---
Write-Host "[*] Polling for job completion (every $PollInterval seconds, max $MaxAttempts attempts)..." -ForegroundColor Cyan

$attempt   = 0
$jobStatus = $null

Start-Sleep -Seconds 1

do {
    $attempt++
    Write-Host "    Attempt $attempt/$MaxAttempts — checking status..." -NoNewline

    $pollResponse = Invoke-RestMethod `
        -Method Get `
        -Uri "$BaseUrl/deviceManagement/reports/exportJobs('$jobId')" `
        -Headers $headers

    $jobStatus = $pollResponse.status
    Write-Host " Status: $jobStatus"

    if ($jobStatus -eq "completed") {
        $JobDuration = (Get-Date) - $JobStart
        Write-Host "[+] Job completed in $([math]::Round($JobDuration.TotalSeconds, 1))s." -ForegroundColor Green
        break
    }
    elseif ($jobStatus -eq "failed") {
        Write-Error "[!] Export job failed."
        exit 1
    }

    if ($attempt -ge $MaxAttempts) {
        Write-Error "[!] Max poll attempts reached without completion."
        exit 1
    }

    Start-Sleep -Seconds $PollInterval

} while ($true)
#endregion

#region --- Step 3: Download the Report ---
$downloadUrl = $pollResponse.url

if (-not $downloadUrl) {
    Write-Error "[!] No download URL found in completed job response."
    exit 1
}

Write-Host "[*] Downloading report..." -ForegroundColor Cyan

$DownloadStart = Get-Date

if (-not (Test-Path $OutputPath)) {
    New-Item -ItemType Directory -Path $OutputPath | Out-Null
}

$zipPath = Join-Path $OutputPath "DeviceConfigPolicyStatuses_$(Get-Date -Format 'yyyyMMdd_HHmmss').zip"

Invoke-WebRequest -Uri $downloadUrl -OutFile $zipPath

$DownloadDuration = (Get-Date) - $DownloadStart
Write-Host "[+] Downloaded in $([math]::Round($DownloadDuration.TotalSeconds, 1))s — saved to: $zipPath" -ForegroundColor Green
#endregion

#region --- Step 4: Extract CSV ---
Write-Host "[*] Extracting CSV..." -ForegroundColor Cyan

Expand-Archive -Path $zipPath -DestinationPath $OutputPath -Force

$csvFiles = Get-ChildItem -Path $OutputPath -Filter "*.csv"
Write-Host "[+] Extracted:" -ForegroundColor Green
$csvFiles | ForEach-Object { Write-Host "    $($_.FullName)" }
#endregion

#region --- Summary ---
$TotalDuration = (Get-Date) - $ScriptStart

Write-Host "`n--- Timing Summary ---" -ForegroundColor Yellow
Write-Host "  Export job duration : $([math]::Round($JobDuration.TotalSeconds, 1))s"
Write-Host "  Download duration   : $([math]::Round($DownloadDuration.TotalSeconds, 1))s"
Write-Host "  Total script time   : $([math]::Round($TotalDuration.TotalSeconds, 1))s"
Write-Host "----------------------" -ForegroundColor Yellow
Write-Host "[✓] Done." -ForegroundColor Green
#endregion
